export FZF_DEFAULT_COMMAND='fd --type f --color=never'
export FZF_ALT_C_COMMAND='fd --type d . --color=never'

function precmd {
	OLDPWD=$PWD
	export OLDPWD
    PWD=$(pwd)
    export PWD
}

find_in_path() {
  name="$1"
  IFS=':' read -ra PATHS <<< "$PATH"
  for path in "${PATHS[@]}"; do
    find "$path" -maxdepth 1 -name "$name" -type f -executable
  done
}


