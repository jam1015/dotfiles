# Toggle git hooks symlinks
dotstogglehooks() {
  local git_dir="$HOME/dotfiles.git/hooks"
  local work_tree="$HOME"
  local post_commit_hook="$git_dir/post-commit"
  local post_merge_hook="$git_dir/post-merge"

  # Check if at least one of the symlinks exists
  if [[ -L "$post_commit_hook" || -L "$post_merge_hook" ]]; then
    # Remove symlinks if they exist
    [[ -L "$post_commit_hook" ]] && rm -f "$post_commit_hook"
    [[ -L "$post_merge_hook" ]] && rm -f "$post_merge_hook"
    echo "Dotfiles hooks removed."
  else
    # Create symlinks if they do not exist
    ln -sf "$work_tree/.dots_hooks/post_commit.bash" "$post_commit_hook"
    ln -sf "$work_tree/.dots_hooks/post_merge.bash" "$post_merge_hook"
    echo "Dotfiles hooks created."
  fi
}

